# Copia este archivo como .env y completa los valores
# NUNCA commitees .env al repositorio

# Microsoft Graph API
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Google Calendar API (pega el JSON completo del service account en una sola línea)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Opcional: nivel de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
