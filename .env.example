# Copia este archivo como .env y completa los valores
# NUNCA commitees .env al repositorio

# URL privada del calendario ICS de Outlook
# Obtenerla desde: Outlook → Configuración → Calendario → Calendarios compartidos → Publicar
OUTLOOK_ICS_URL=https://outlook.office365.com/owa/calendar/.../.../calendar.ics

# Google Calendar API (JSON completo del service account en una sola línea)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Opcional: nivel de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
